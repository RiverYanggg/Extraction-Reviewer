DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
ENVIZ_ASSISTANT_MODEL=deepseek-v4-flash

# 上云部署前请改成随机长字符串，用于签名登录 Cookie。
ENVIZ_AUTH_SECRET=replace-with-a-long-random-secret

# 可选：用 JSON 覆盖默认账号。password_sha256 是明文密码的 SHA-256。
# workspace 是该账号的工作区目录名；不写时默认等于账号名。
# 生成方式：python3 -c "import hashlib; print(hashlib.sha256('你的密码'.encode()).hexdigest())"
# ENVIZ_USERS_JSON={"user1":{"display_name":"User 1","workspace":"user1","password_sha256":"..."}}
