DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
ENVIZ_ASSISTANT_MODEL=deepseek-v4-flash

# 上云部署前请改成随机长字符串，用于签名登录 Cookie。
ENVIZ_AUTH_SECRET=replace-with-a-long-random-secret

# 用户账号推荐统一写在 config/users.json。
# password_sha256 生成方式：python3 -c "import hashlib; print(hashlib.sha256('你的密码'.encode()).hexdigest())"
# 如果 config/users.json 不存在，也可以用 ENVIZ_USERS_JSON 兼容旧的一行配置方式。
