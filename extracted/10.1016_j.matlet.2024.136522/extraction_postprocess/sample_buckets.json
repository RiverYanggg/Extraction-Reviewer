      "records": {
        "paper": {
          "doi": "10.1016/j.matlet.2024.136522",
          "title": "Co-precipitation mechanism of Cu-rich phase and κ-carbide precipitates in Fe-28Mn-10Al-1C-3Cu austenitic low-density steel",
          "authors": [
            "Xiqiang Ren",
            "Yanfei Qi",
            "Yungang Li",
            "Jingyi Zhou",
            "Jiahao Gu"
          ],
          "publication_year": "2024",
          "journal": "Materials Letters",
          "keywords": [
            "Austenitic low-density steel",
            "Particles",
            "Nanosize",
            "Microstructure",
            "Co-precipitation mechanism"
          ],
          "research_type": "experimental",
          "paper_scope": "Investigation of co-precipitation mechanism of Cu-rich phase and κ-carbide in Fe-28Mn-10Al-1C-3Cu austenitic low-density steel"
        },
        "characterization_methods": [
          {
            "characterization_id": "char_all_xrd",
            "technique": "X-ray diffraction (XRD)",
            "purpose": "Determine lattice parameters of austenitic matrix",
            "key_findings": "Lattice parameter of 0Cu steel: a=0.3687 nm; 3Cu steel: a=0.3689 nm (solution treated)."
          }
        ],
        "computational_details": [
          {
            "computation_id": "comp_lattice_misfit",
            "sample_id": "sample_3cu_sol_aged",
            "simulation_method": "Lattice misfit calculation using formula δ = |a0 - a1| / a0",
            "validation_against_experiment": "Calculated misfits: κ-carbide/γ=2.3%, Cu-rich/γ=1.0%, κ-carbide/Cu-rich=3.4%.",
            "analytical_model": [
              {
                "model_name": "Lattice misfit formula",
                "equation_role": "Calculate lattice misfit between phases",
                "parameters": "a0 and a1: lattice parameters of two phases",
                "model_note": "Formula (1) in text."
              },
              {
                "model_name": "Composition boundary formula for intragranular κ-carbide precipitation",
                "equation_role": "Predict precipitation condition for κ-carbide based on composition",
                "parameters": "0.208(wt.% C) + 0.098(wt.% Al) = 1 - 0.0054(wt.% Mn)",
                "model_note": "Formula (2) in text; critical Al content for 0Cu steel calculated as 6.52 wt%."
              }
            ]
          }
        ],
        "unmapped_findings": [
          "The Cu-rich phase in ferrite generally precipitates with BCC structure first then transforms to FCC; but in austenite, it precipitates directly in FCC structure.",
          "Interfacial energy: κ-carbide with austenitic matrix = 0.025 J/m^2; Cu in austenitic matrix = 0.086 J/m^2.",
          "κ-carbide precipitation follows nucleation and growth mechanism; critical lattice parameter of austenitic matrix for intragranular κ-carbide is about a=0.3670 nm.",
          "Cu addition increases lattice parameter of austenitic matrix, beneficial for κ-carbide precipitation.",
          "Cu-rich phase crystal plane spacing (002) = 0.182 nm, consistent with FCC Cu.",
          "The κ-carbide and Cu-rich phase have good thermal stability due to low lattice misfit."
        ]
      }
    },
